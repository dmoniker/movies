# Server-only API keys (never use NEXT_PUBLIC_ — these stay off the client bundle)
# Local: copy to .env.local
# Vercel: Project → Settings → Environment Variables

# Get TMDB key at https://www.themoviedb.org/settings/api (API Key v3 auth)
TMDB_API_KEY=your_tmdb_api_key_here

# Optional: x.ai (Grok) key for smarter recommendations — https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here
